class Solution {
    public int[] intersection(int[] nums1, int[] nums2) {
     
      Set<Integer> set=new HashSet<>();
        for(int n:nums1){
            set.add(n);
        }
       Set<Integer> result=new HashSet<>();
      for(int n1:nums2){
        if(set.contains(n1)){
            result.add(n1);
        }       
      }
      int[] output=new int[result.size()];
int val=0;

for(int n:result){
    output[val]=n;
    val++;
}
       return  output;
    }
}
