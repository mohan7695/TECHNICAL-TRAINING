class Solution {
    public String[] findRelativeRanks(int[] score) {
        class Pair{
         
            int val;
               int index;

            Pair(int val,int index){
                
                this.val=val;
                this.index=index;
            }
        }
PriorityQueue<Pair> q=new PriorityQueue<>((a,b) -> b.val - a.val);

for(int i=0;i<score.length;i++){
    q.add(new Pair(score[i],i));
}
int rank=1;
String ans[] =new String[score.length];
  
while(!q.isEmpty()){
     Pair current=q.poll();

   if(rank == 1 ) {
    ans[current.index]="Gold Medal";
 
   }
   else if(rank == 2){

   ans[current.index] ="Silver Medal";
  
   }
    else if( rank == 3) {
        ans[current.index] = "Bronze Medal";
    }
    else {
        ans[current.index]=String.valueOf(rank);
    }
    rank++;
    
}
return ans;
    }
}
