class Solution {
    public int differenceOfSum(int[] nums) {
        int sum=0;
        int val=0;
        for(int n:nums){
            sum+=n;
        }
for(int i:nums){
        if(i<9){
            val+=i;
        }
        else{
            
            while(i>0){
                int d=i%10;
                val+=d;
                i/=10;
            }
        }

} 

        return Math.abs(sum-val);
    }
}
