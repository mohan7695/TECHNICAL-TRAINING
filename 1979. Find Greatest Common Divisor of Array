class Solution {
    public int findGCD(int[] nums) {
        
        int max=0;
        int min=Integer.MAX_VALUE;

        int n=nums.length;
        if(n<2){
            return -1;
        }
        for(int i=0;i<n;i++){
           max=Math.max(max,nums[i]);
           min=Math.min(min,nums[i]);
        }
        int a=min;
        int b=max;

        while(b!=0){
          
          int temp=b;
          b=a%b;
          a=temp;
        }
return a;
    }
}
