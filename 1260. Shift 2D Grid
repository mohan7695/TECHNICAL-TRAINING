class Solution {
    public List<List<Integer>> shiftGrid(int[][] grid, int k) {
        int m=grid.length;
        int n=grid[0].length;
        int[][] ans=new int[m][n];
       // List<Integer> ans =new ArrayList<>();
int total=m*n;
k%=total;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                int old_Index=i*n+j;
                int newIndex=(old_Index+k)%total;
                int newRow=newIndex/n;
                int newColumn=newIndex%n;

                ans[newRow][newColumn]= grid[i][j];
            }
        }
        List<List<Integer>> list=new ArrayList<>();
        for(int i=0;i<m;i++){
            List<Integer> row=new ArrayList<>();
            for(int j=0;j<n;j++){
                row.add(ans[i][j]);
            }
            list.add(row);
        }
        return list;
    }
}
