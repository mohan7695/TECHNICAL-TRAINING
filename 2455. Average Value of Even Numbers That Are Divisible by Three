class Solution {
    public int averageValue(int[] nums) {
        int d=0;
        int count=0;
        
        for(int i=0;i<nums.length;i++){

            if(nums[i]%3==0){
                if((nums[i]&1)==0){
                    d+=nums[i];
                    count++;

                }
               
            }
        } 
         if(count==0) return 0;
        
        return d/count;
    }
}
